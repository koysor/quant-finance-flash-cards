# Copy this file to .env and fill in values for your environment.
# The app works without any of these set — defaults are fine for local development.

# Flask session signing key. Set a stable value in production so sessions survive restarts.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-stable-secret-key-here

# Port for the development server (default: 5000).
PORT=5000

# Set to "false" in production to disable the Flask debugger and interactive reloader.
DEBUG=true
